# === Telegram ===
# Токен бота от @BotFather
BOT_TOKEN=8866149663:AAEpiUhP2bjkaGpFpTutGQYuue8H7jHc4Bk
# Username бота без @ — нужно для триггера на нативный @mention
BOT_USERNAME=minecraft_banda_bot

# === Триггер ответа ===
# Текстовая фраза (case-insensitive), на которую бот отвечает.
# Если в сообщении есть это слово/фразу — бот отвечает.
TRIGGER_PHRASE=сильвер

# === Контекст ===
# Сколько часов без обращения к боту держать контекст до автоочистки
CONTEXT_TTL_HOURS=6
# Сколько последних сообщений группы передавать модели как контекст беседы
HISTORY_WINDOW=15

# === Таймзона ===
# Используется для /summary («за вчера») и для разбиения history по датам
TIMEZONE=Europe/Moscow

# === Модель ===
MODEL_PATH=models/Qwen3.6-27B-Q4_K_P.gguf
N_GPU_LAYERS=-1
N_CTX=24576
MAX_TOKENS=1024
TEMPERATURE=0.5
TOP_P=0.9
REPEAT_PENALTY=1.15

# === Хранилище ===
# Директория для runtime-данных (история, контекст, память). Python-пакет storage/ — отдельно.
DATA_DIR=data
