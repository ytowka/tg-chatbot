# === Telegram ===
# Токен бота от @BotFather
BOT_TOKEN=8866149663:AAEpiUhP2bjkaGpFpTutGQYuue8H7jHc4Bk
# Username бота без @ — нужно для триггера на нативный @mention
BOT_USERNAME=minecraft_banda_bot

# === Триггер ответа ===
# Текстовая фраза (case-insensitive), на которую бот отвечает.
# Если в сообщении есть это слово/фразу — бот отвечает.
TRIGGER_PHRASE=сильвер

# === Случайные ответы ===
# Вероятность ответа на любое сообщение (даже без триггера), когда флаг
# включён командой /randomreply. 0.03 = 3%.
RANDOM_REPLY_CHANCE=0.03

# === Контекст ===
# Сколько часов без обращения к боту держать контекст до автоочистки
CONTEXT_TTL_HOURS=6
# Сколько последних сообщений группы передавать модели как контекст беседы
HISTORY_WINDOW=15

# === Таймзона ===
# Используется для /summary («за вчера») и для разбиения history по датам
TIMEZONE=Europe/Moscow

# === LLM Backend ===
# local — llama-server на ноутбуке (через SSH reverse tunnel на localhost:8081)
# api   — облачный API (зарезервировано на будущее)
LLM_MODE=local
LLM_BASE_URL=http://127.0.0.1:8081/v1
LLM_MODEL=qwen3.5-9b
LLM_API_KEY=not-needed
LLM_REQUEST_TIMEOUT=120

# === Генерация ===
MAX_TOKENS=2048
TEMPERATURE=0.4
TOP_P=0.9
REPEAT_PENALTY=1.15

# === Хранилище ===
# Директория для runtime-данных (история, контекст, память). Python-пакет storage/ — отдельно.
DATA_DIR=data
