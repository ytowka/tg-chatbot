{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8082/v1"
      },
      "models": {
        "glm-4.7-flash": {
          "name": "GLM-4.7-Flash (local)",
          "limit": {
            "context": 130000,
            "output": 24576
          }
        }
      }
    }
  },
  "plugin": [
    "opencode-browser"
  ],
  "experimental": {
    "disable_paste_summary": true,
    "timeout_ms": 60000000,
    "max_lines": null,
    "max_bytes": null
  },
  "mcp": {
    "browsermcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp@0.1.3"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:ctx7sk-0ab3c035-cb5e-4983-b87a-3d81bae8f85e}"
      }
    }
  },
  "watcher": {
    "ignore": [
      "text/"
    ]
  }
}
